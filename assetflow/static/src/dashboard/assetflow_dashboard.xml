<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="assetflow.Dashboard">
        <div class="o_assetflow_dashboard p-4">
            <div class="assetflow_hero d-flex justify-content-between align-items-start flex-wrap">
                <div>
                    <h2 class="mb-1 text-white">AssetFlow Dashboard</h2>
                    <div class="text-white-50">Real-time overview of your organization's assets</div>
                </div>
                <div class="d-flex gap-2 mt-2 mt-md-0">
                    <button class="btn assetflow_hero_btn_solid" t-on-click="() => this.quickCreate('asset.asset', 'Register Asset')">
                        <i class="fa fa-plus me-1"/>Register Asset
                    </button>
                    <button class="btn assetflow_hero_btn_ghost" t-on-click="() => this.quickCreate('resource.booking', 'New Booking')">
                        <i class="fa fa-calendar me-1"/>Book Resource
                    </button>
                    <button class="btn assetflow_hero_btn_ghost" t-on-click="() => this.quickCreate('asset.maintenance.request', 'Raise Maintenance Request')">
                        <i class="fa fa-wrench me-1"/>Raise Maintenance
                    </button>
                </div>
            </div>

            <div class="assetflow_kpi_grid">
                <div class="assetflow_kpi_card" t-on-pointermove="onCardPointerMove" t-on-click="() => this.openAssets([['state', '=', 'available']])" style="--i: 0">
                    <div class="assetflow_kpi_icon assetflow_tint_success"><i class="fa fa-check-circle"/></div>
                    <div>
                        <div class="assetflow_kpi_value" t-esc="state.available"/>
                        <div class="assetflow_kpi_label">Assets Available</div>
                    </div>
                </div>
                <div class="assetflow_kpi_card" t-on-pointermove="onCardPointerMove" t-on-click="() => this.openAssets([['state', '=', 'allocated']])" style="--i: 1">
                    <div class="assetflow_kpi_icon assetflow_tint_primary"><i class="fa fa-user"/></div>
                    <div>
                        <div class="assetflow_kpi_value" t-esc="state.allocated"/>
                        <div class="assetflow_kpi_label">Assets Allocated</div>
                    </div>
                </div>
                <div class="assetflow_kpi_card" t-on-pointermove="onCardPointerMove" t-on-click="() => this.openMaintenance([['state', 'in', ['approved', 'in_progress']]])" style="--i: 2">
                    <div class="assetflow_kpi_icon assetflow_tint_warning"><i class="fa fa-wrench"/></div>
                    <div>
                        <div class="assetflow_kpi_value" t-esc="state.maintenance"/>
                        <div class="assetflow_kpi_label">Maintenance Active</div>
                    </div>
                </div>
                <div class="assetflow_kpi_card" t-on-pointermove="onCardPointerMove" t-on-click="() => this.openBookings([['state', 'in', ['upcoming', 'ongoing']]])" style="--i: 3">
                    <div class="assetflow_kpi_icon assetflow_tint_info"><i class="fa fa-calendar"/></div>
                    <div>
                        <div class="assetflow_kpi_value" t-esc="state.bookings"/>
                        <div class="assetflow_kpi_label">Active Bookings</div>
                    </div>
                </div>
                <div class="assetflow_kpi_card" t-on-pointermove="onCardPointerMove" t-on-click="() => this.openTransfers([['state', '=', 'requested']])" style="--i: 4">
                    <div class="assetflow_kpi_icon assetflow_tint_secondary"><i class="fa fa-exchange"/></div>
                    <div>
                        <div class="assetflow_kpi_value" t-esc="state.transfers"/>
                        <div class="assetflow_kpi_label">Pending Transfers</div>
                    </div>
                </div>
                <div class="assetflow_kpi_card" t-on-pointermove="onCardPointerMove" t-on-click="() => this.openAllocations([['is_overdue', '=', true]])" style="--i: 5">
                    <div class="assetflow_kpi_icon assetflow_tint_danger"><i class="fa fa-exclamation-triangle"/></div>
                    <div>
                        <div class="assetflow_kpi_value" t-esc="state.overdue"/>
                        <div class="assetflow_kpi_label">Overdue Returns</div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
