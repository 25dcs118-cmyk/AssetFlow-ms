<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_asset_maintenance_request_kanban" model="ir.ui.view">
        <field name="name">asset.maintenance.request.kanban</field>
        <field name="model">asset.maintenance.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column assetflow_kanban">
                <field name="asset_id"/>
                <field name="requester_id"/>
                <field name="technician_id"/>
                <field name="description"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click assetflow_kanban_card">
                            <div class="o_kanban_record_top">
                                <strong class="o_kanban_record_title"><field name="asset_id"/></strong>
                            </div>
                            <div class="o_kanban_record_body mt-2">
                                <div class="text-muted small text-truncate"><field name="description"/></div>
                                <div class="mt-1"><i class="fa fa-user text-muted me-1" title="Requester"/><field name="requester_id"/></div>
                                <div t-if="record.technician_id.value"><i class="fa fa-wrench text-muted me-1" title="Technician"/><field name="technician_id"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_asset_maintenance_request_tree" model="ir.ui.view">
        <field name="name">asset.maintenance.request.tree</field>
        <field name="model">asset.maintenance.request</field>
        <field name="arch" type="xml">
            <tree decoration-muted="state in ('rejected', 'resolved')" decoration-warning="state == 'approved'">
                <field name="asset_id"/>
                <field name="requester_id"/>
                <field name="technician_id"/>
                <field name="request_date"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'pending'" decoration-warning="state in ('approved', 'in_progress')"
                       decoration-success="state == 'resolved'" decoration-danger="state == 'rejected'"/>
            </tree>
        </field>
    </record>

    <record id="view_asset_maintenance_request_search" model="ir.ui.view">
        <field name="name">asset.maintenance.request.search</field>
        <field name="model">asset.maintenance.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="asset_id"/>
                <field name="requester_id"/>
                <filter string="Pending" name="filter_pending" domain="[('state', '=', 'pending')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_asset_maintenance_request_form" model="ir.ui.view">
        <field name="name">asset.maintenance.request.form</field>
        <field name="model">asset.maintenance.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" type="object" string="Approve"
                            class="oe_highlight" invisible="state != 'pending'"/>
                    <button name="action_reject" type="object" string="Reject"
                            invisible="state != 'pending'"/>
                    <button name="action_start" type="object" string="Start Work"
                            invisible="state != 'approved'"/>
                    <button name="action_resolve" type="object" string="Resolve"
                            invisible="state not in ('approved', 'in_progress')"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,approved,in_progress,resolved"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="asset_id"/>
                            <field name="requester_id" readonly="1"/>
                            <field name="technician_id"/>
                        </group>
                        <group>
                            <field name="request_date" readonly="1"/>
                            <field name="approval_date" readonly="1"/>
                            <field name="resolution_date" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                        <field name="resolution_notes"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_asset_maintenance_request_action" model="ir.actions.act_window">
        <field name="name">Maintenance Requests</field>
        <field name="res_model">asset.maintenance.request</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_asset_maintenance_request_search"/>
        <field name="context">{'search_default_filter_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Raise a maintenance request</p>
            <p>Track repair requests from raised through resolved.</p>
        </field>
    </record>
</odoo>
