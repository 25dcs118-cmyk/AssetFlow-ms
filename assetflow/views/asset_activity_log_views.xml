<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_asset_activity_log_tree" model="ir.ui.view">
        <field name="name">asset.activity.log.tree</field>
        <field name="model">asset.activity.log</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0" delete="0">
                <field name="timestamp"/>
                <field name="res_model"/>
                <field name="action"/>
                <field name="actor_id"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="view_asset_activity_log_search" model="ir.ui.view">
        <field name="name">asset.activity.log.search</field>
        <field name="model">asset.activity.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="res_model"/>
                <field name="actor_id"/>
                <field name="action"/>
                <group expand="0" string="Group By">
                    <filter string="Model" name="group_model" context="{'group_by': 'res_model'}"/>
                    <filter string="Actor" name="group_actor" context="{'group_by': 'actor_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_asset_activity_log_action" model="ir.actions.act_window">
        <field name="name">Audit Log</field>
        <field name="res_model">asset.activity.log</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="view_asset_activity_log_search"/>
    </record>
</odoo>
