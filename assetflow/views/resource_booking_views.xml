<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_resource_booking_tree" model="ir.ui.view">
        <field name="name">resource.booking.tree</field>
        <field name="model">resource.booking</field>
        <field name="arch" type="xml">
            <tree decoration-muted="state in ('cancelled', 'completed')" decoration-info="state == 'ongoing'">
                <field name="asset_id"/>
                <field name="requester_id"/>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_resource_booking_calendar" model="ir.ui.view">
        <field name="name">resource.booking.calendar</field>
        <field name="model">resource.booking</field>
        <field name="arch" type="xml">
            <calendar date_start="start_datetime" date_stop="end_datetime" string="Bookings" color="asset_id">
                <field name="asset_id"/>
                <field name="requester_id"/>
            </calendar>
        </field>
    </record>

    <record id="view_resource_booking_form" model="ir.ui.view">
        <field name="name">resource.booking.form</field>
        <field name="model">resource.booking</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state not in ('upcoming', 'ongoing')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="asset_id"/>
                            <field name="requester_id"/>
                            <field name="purpose"/>
                        </group>
                        <group>
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_resource_booking_action" model="ir.actions.act_window">
        <field name="name">Bookings</field>
        <field name="res_model">resource.booking</field>
        <field name="view_mode">calendar,tree,form</field>
    </record>

    <record id="view_resource_booking_pivot" model="ir.ui.view">
        <field name="name">resource.booking.pivot</field>
        <field name="model">resource.booking</field>
        <field name="arch" type="xml">
            <pivot string="Booking Utilization">
                <field name="asset_id" type="row"/>
                <field name="state" type="col"/>
                <field name="duration_hours" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_resource_booking_graph" model="ir.ui.view">
        <field name="name">resource.booking.graph</field>
        <field name="model">resource.booking</field>
        <field name="arch" type="xml">
            <graph string="Booking Utilization" type="bar">
                <field name="asset_id"/>
                <field name="duration_hours" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_resource_booking_report" model="ir.actions.act_window">
        <field name="name">Booking Utilization</field>
        <field name="res_model">resource.booking</field>
        <field name="view_mode">pivot,graph</field>
    </record>
</odoo>
