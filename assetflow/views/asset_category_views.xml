<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_asset_category_tree" model="ir.ui.view">
        <field name="name">asset.category.tree</field>
        <field name="model">asset.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="warranty_period"/>
                <field name="asset_count"/>
            </tree>
        </field>
    </record>

    <record id="view_asset_category_form" model="ir.ui.view">
        <field name="name">asset.category.form</field>
        <field name="model">asset.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="parent_id"/>
                        </group>
                        <group>
                            <field name="warranty_period"/>
                            <field name="default_bookable"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_asset_category_action" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">asset.category</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
