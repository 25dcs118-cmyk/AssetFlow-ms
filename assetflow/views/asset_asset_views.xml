<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_asset_asset_tree" model="ir.ui.view">
        <field name="name">asset.asset.tree</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'available'" decoration-info="state == 'allocated'"
                  decoration-warning="state in ('reserved', 'maintenance')" decoration-muted="state in ('lost', 'retired')">
                <field name="tag"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="department_id"/>
                <field name="current_holder"/>
                <field name="condition"/>
                <field name="is_shared"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_asset_asset_search" model="ir.ui.view">
        <field name="name">asset.asset.search</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <search>
                <field name="tag"/>
                <field name="name"/>
                <field name="serial_number"/>
                <field name="category_id"/>
                <field name="department_id"/>
                <filter string="Available" name="filter_available" domain="[('state', '=', 'available')]"/>
                <filter string="Allocated" name="filter_allocated" domain="[('state', '=', 'allocated')]"/>
                <filter string="Under Maintenance" name="filter_maintenance" domain="[('state', '=', 'maintenance')]"/>
                <filter string="Shared / Bookable" name="filter_shared" domain="[('is_shared', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_asset_asset_form" model="ir.ui.view">
        <field name="name">asset.asset.form</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_new_allocation" type="object" string="Allocate"
                            class="oe_highlight" invisible="state != 'available'"/>
                    <button name="action_open_new_transfer" type="object" string="Request Transfer"
                            invisible="state != 'allocated'"/>
                    <button name="action_open_new_booking" type="object" string="Book"
                            invisible="not is_shared or state != 'available'"/>
                    <button name="action_open_new_maintenance" type="object" string="Raise Maintenance Request"
                            invisible="state not in ('available', 'allocated')"/>
                    <button name="action_mark_lost" type="object" string="Mark Lost"
                            invisible="state in ('lost', 'retired')" confirm="Mark this asset as Lost?"/>
                    <button name="action_retire" type="object" string="Retire"
                            invisible="state in ('lost', 'retired')" confirm="Retire this asset? This cannot be undone."/>
                    <field name="state" widget="statusbar" statusbar_visible="available,allocated,reserved,maintenance"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Lost" bg_color="text-bg-danger" invisible="state != 'lost'"/>
                    <widget name="web_ribbon" title="Retired" bg_color="text-bg-secondary" invisible="state != 'retired'"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Laptop"/></h1>
                        <h3><field name="tag" readonly="1"/></h3>
                    </div>
                    <group>
                        <group>
                            <field name="category_id"/>
                            <field name="department_id"/>
                            <field name="serial_number"/>
                            <field name="location"/>
                        </group>
                        <group>
                            <field name="condition"/>
                            <field name="is_shared"/>
                            <field name="current_holder" readonly="1"/>
                            <field name="acquisition_date"/>
                            <field name="acquisition_cost"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Allocations">
                            <field name="allocation_ids" readonly="1">
                                <tree>
                                    <field name="holder_name"/>
                                    <field name="allocation_date"/>
                                    <field name="expected_return_date"/>
                                    <field name="actual_return_date"/>
                                    <field name="is_overdue"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Bookings" invisible="not is_shared">
                            <field name="booking_ids" readonly="1">
                                <tree>
                                    <field name="requester_id"/>
                                    <field name="start_datetime"/>
                                    <field name="end_datetime"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Maintenance">
                            <field name="maintenance_ids" readonly="1">
                                <tree>
                                    <field name="requester_id"/>
                                    <field name="request_date"/>
                                    <field name="technician_id"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_asset_asset_action" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">asset.asset</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_asset_asset_search"/>
        <field name="context">{'search_default_filter_available': 0}</field>
    </record>
</odoo>
